# Ollama (Local AI — no API key needed)
OLLAMA_API_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.1

# SerpAPI (Web Search)
SEARCH_API_KEY=your-serpapi-key-here
SEARCH_API_URL=https://serpapi.com/search

# Unsplash (Stock Photos)
STOCK_PHOTO_API_KEY=your-unsplash-access-key-here
STOCK_PHOTO_API_URL=https://api.unsplash.com/search/photos

# Your CMS (Strapi)
CMS_API_URL=http://localhost:1337
CMS_API_KEY=your-strapi-api-key-here

# PostgreSQL
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Local Image Storage
IMAGE_UPLOAD_DIR=uploads/images
IMAGE_BASE_URL=http://localhost:8080/images

# Email Alerts
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Admin
ADMIN_EMAIL=your-email@gmail.com
ADMIN_API_KEY=your-admin-api-key
